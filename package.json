{
  "name": "thrust-app",
  "version": "0.1.0",
  "description": "Thrust - hyper-optimized full-stack micro-framework for AI coding agents",
  "type": "module",
  "scripts": {
    "dev": "bun run scripts/dev.ts",
    "dev:server": "bun run --watch src/index.tsx",
    "test": "bun test src/",
    "test:watch": "bun test --watch src/",
    "build:css": "bunx @tailwindcss/cli -i tailwind.css -o public/style.css",
    "build:css:watch": "bunx @tailwindcss/cli -i tailwind.css -o public/style.css --watch",
    "build:client": "bun run scripts/build-client.ts",
    "build:client:watch": "bun run scripts/build-client.ts --watch",
    "db:reset": "rm -rf data/app.db data/app.db-wal data/app.db-shm && echo 'Database reset'",
    "create-thrust:sync": "node scripts/sync-create-thrust-template.js",
    "create-thrust:test": "rm -rf /tmp/create-thrust-test && node packages/create-thrust/bin/create-thrust.js /tmp/create-thrust-test --no-install",
    "create-thrust:variant-test": "node scripts/test-create-thrust-variants.js",
    "create-thrust:pack-test": "node scripts/test-create-thrust-pack.js"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.7.0",
    "hono": "^4.7.0",
    "drizzle-orm": "^0.44.0",
    "better-auth": "^1.2.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.1.0",
    "@types/bun": "^1.2.0",
    "daisyui": "^5.0.0",
    "tailwindcss": "^4.1.0"
  }
}
