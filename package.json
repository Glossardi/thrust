{
  "name": "thrust-app",
  "version": "0.1.0",
  "description": "Thrust — hyper-optimized full-stack micro-framework for AI coding agents",
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.tsx",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "build:css": "bunx @tailwindcss/cli -i tailwind.css -o public/style.css",
    "db:push": "drizzle-kit push",
    "db:reset": "rm -rf data/app.db data/app.db-wal data/app.db-shm && echo '✓ Database reset'"
  },
  "dependencies": {
    "hono": "^4.7.0",
    "htmx.org": "^2.0.0",
    "drizzle-orm": "^0.44.0",
    "better-auth": "^1.2.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.1.0",
    "daisyui": "^5.0.0",
    "tailwindcss": "^4.1.0",
    "drizzle-kit": "^0.31.0",
    "@types/bun": "^1.2.0"
  }
}
